# =============================================================================
# Mine-Ops Environment Variables
# Copy this file to .env and update values before running docker compose
# =============================================================================

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mineops

# Backend
# Full database URL is constructed automatically in docker-compose.yml
# Change SECRET_KEY to a long random string in production!
SECRET_KEY=changeme-use-a-strong-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend
# VITE_API_BASE_URL is ONLY used when running the frontend with `npm run dev` (local development).
# When running via Docker + nginx, API calls are proxied automatically — do NOT set this to an IP.
# For local dev, leave as http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
