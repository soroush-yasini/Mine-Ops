# =============================================================================
# Mine-Ops Environment Variables
# Copy this file to .env and update values before running docker compose
# =============================================================================

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mineops

# Backend
# Full database URL is constructed automatically in docker-compose.yml
# Change SECRET_KEY to a long random string in production!
SECRET_KEY=changeme-use-a-strong-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend
# URL of the backend API (used by the browser to call the API in production)
# Set this to the publicly accessible backend address, e.g. http://<your-server-ip>:8000
VITE_API_BASE_URL=http://localhost:8000
